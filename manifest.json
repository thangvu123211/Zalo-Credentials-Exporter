{
  "manifest_version": 3,
  "name": "Zalo Credentials Exporter",
  "version": "1.0.0",

  "permissions": [
    "cookies",
    "downloads",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://chat.zalo.me/*",
    "https://*.zalo.me/*"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  }
}